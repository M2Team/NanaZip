<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="WixToolset.Sdk/5.0.2">
  <PropertyGroup>
    <Version>5.1.$([System.DateTime]::Today.Subtract($([System.DateTime]::Parse('2021-08-31'))).TotalDays).0</Version>
    <DefineConstants>Version=$(Version)</DefineConstants>
    <OutputName>$(MSBuildProjectName)-$(Version)</OutputName>
    <OutputPath>..\Output\Binaries\$(Configuration)\$(MSBuildProjectName)\$(Platform)\</OutputPath>
    <BindFiles>true</BindFiles>
  </PropertyGroup>
</Project>
