<Page
  x:Class="NanaZip.Modern.PasswordPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:local="using:NanaZip.Modern"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  IsTextScaleFactorEnabled="False"
  mc:Ignorable="d">
  <Grid Padding="24,0" VerticalAlignment="Top">
    <Grid.ColumnDefinitions>
      <ColumnDefinition />
      <ColumnDefinition Width="8"/>
      <ColumnDefinition Width="Auto" />
    </Grid.ColumnDefinitions>
    <PasswordBox x:Name="PasswordBoxInput" x:Uid="/NanaZip.Modern/PasswordPage/PasswordBoxInput" d:PlaceholderText="[Enter archive's password]" Grid.Column="0">
      <PasswordBox.Header>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xEC19;" FontSize="32" />
          <TextBlock x:Uid="/NanaZip.Modern/PasswordPage/PasswordBoxInputHeader" d:Text="[Password]" VerticalAlignment="Center" />
        </StackPanel>
      </PasswordBox.Header>
    </PasswordBox>
    <Button VerticalAlignment="Bottom" Grid.Column="2" Click="OKButtonClick">
      <SymbolIcon Symbol="Accept" />
      <Button.KeyboardAccelerators>
        <KeyboardAccelerator x:Name="OkKeyAcc" Modifiers="None" Key="Enter" />
      </Button.KeyboardAccelerators>
    </Button>
  </Grid>
</Page>
